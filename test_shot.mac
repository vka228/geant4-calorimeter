#Тестовый макрос для проверки генератора
/run/initialize

# Устанавливаем частицу
/gun/particle e-
/gun/energy 1 GeV
/gun/position 0 0 -50 cm
/gun/direction 0 0 1

# Включаем визуализацию треков
/vis/open OGLI 800x800-0+0
/vis/drawVolume
/vis/scene/add/trajectories smooth
/tracking/storeTrajectory 1

# Запускаем 1 событие
/run/beamOn 1

# Ждем команды пользователя
/vis/viewer/flush
EOF